{
  "expo": {
    "name": "Hifz Cards",
    "slug": "hifz-cards",
    "scheme": "hifzcards",
    "version": "1.0.0",
    "orientation": "portrait",
    "jsEngine": "hermes",
    "newArchEnabled": false,
    "userInterfaceStyle": "light",
    "backgroundColor": "#f6f2ea",
    "icon": "./assets/app-icon/icon-ios.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yacoobali.hifz",
      "icon": "./assets/app-icon/icon-ios.png"
    },
    "android": {
      "package": "com.yacoobali.hifz",
      "icon": "./assets/app-icon/icon-android.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon/icon-android.png",
        "backgroundColor": "#0f3b30"
      },
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#0f3b30",
          "defaultChannel": "hifz-cards"
        }
      ],
      "expo-audio",
      "expo-font"
    ]
  }
}
